# Real-posting scoring benchmarks contain posting text and private preference
# labels. Keep the documentation/tests trackable while all generated sets stay
# local and out of workflow artifacts.
evaluation/private/
evaluation/scoring_*_labels.csv
evaluation/scoring_*_rows.jsonl
evaluation/scoring_*_predictions.json
evaluation/scoring_*_manifest.json
evaluation/scoring_*_report.md
evaluation/scoring_*_metrics.json

# Local watcher scratch artifacts
check_alumni_coverage.py
watcher/add_company_batch.txt
watcher/additions_detect.json
watcher/additions_report.md
watcher/additions_watchlist.yml
# Optional machine-readable source-health reports generated by
# WATCHER_HEALTH_REPORT_PATH / --health-report. Keep the Python module and
# offline JSON fixtures trackable by limiting these to explicit report names.
watcher-health*.json
watcher-source-health*.json
health-report*.json
source-health*.json
watcher/health-report*.json
watcher/source-health*.json
# Sanitized summaries from isolated reliability probes belong outside source
# control even when a local run writes them in the repository root.
watcher-reliability-probe*.json
watcher/reliability-probe*.json
# Local direct-adapter probe captures must not become fixtures accidentally.
workday-live-probe*.json
workday-live-probe*.log
watcher/workday-live-probe*.json
watcher/workday-live-probe*.log
# Safe Workday transport probe output is operational scratch data. The probe
# script and offline test fixtures remain trackable.
workday-transport-probe*.json
workday-transport-probe*.log
watcher/workday-transport-probe*.json
watcher/workday-transport-probe*.log
# Keep canonical agents.md/AGENTS.md files trackable; ignore local copies.
agents.local.md
agents.*.md
agents (*).md
AGENTS.local.md
AGENTS.*.md
AGENTS (*).md
# Keep the canonical root claude.md trackable; ignore local instruction copies
# and Claude Code's machine-specific settings.
claude.local.md
claude.*.md
claude (*).md
CLAUDE.local.md
CLAUDE.*.md
CLAUDE (*).md
.claude/settings.local.json
# Keep the canonical root WATCHER_PROGRESS.md tracked; ignore local copies.
WATCHER_PROGRESS.local.md
WATCHER_PROGRESS.*.md
WATCHER_PROGRESS (*).md
watcher/WATCHER_PROGRESS*.md
watcher/WATCHER_PROGRESS (*).md
