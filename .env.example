# Internship Signal — optional settings. Everything works with defaults;
# copy to .env and uncomment only what you need.

# --- backend -----------------------------------------------------------
# Host/port uvicorn binds to (passed on the command line in the README,
# listed here for completeness):
#   uvicorn app.main:app --host $BACKEND_HOST --port $BACKEND_PORT
#BACKEND_HOST=127.0.0.1
#BACKEND_PORT=8000

# Comma-separated origins allowed by CORS (only needed if you serve the
# frontend from somewhere other than the Vite dev proxy).
#CORS_ORIGINS=http://localhost:5173

# Override the bundled data files:
#KNOWN_COMPANIES_PATH=./data/known_companies.json
#PROFILE_PATH=./data/profile.json
#SAMPLE_CSV_PATH=./data/sample_postings.csv

# --- frontend ----------------------------------------------------------
# Where the Vite dev server proxies /api requests (default shown).
#VITE_API_BASE=http://localhost:8000

# --- watcher email -----------------------------------------------------
# PowerShell examples for enabling live Gmail SMTP sends:
$env:SMTP_USER = "youraddress@gmail.com"
$env:SMTP_APP_PASSWORD = "abcdefghijklmnop"
$env:EMAIL_TO = "youraddress@gmail.com"
$env:WATCHER_SEND_EMAIL = "1"
# Explicit dry-run override (also accepts false, no, or off):
#$env:WATCHER_SEND_EMAIL = "0"

# Optional compact private company alumni JSON map. This is preferred over the
# full CSV when present and is small enough to store as a base64 Actions secret.
#$env:WATCHER_COMPANY_ALUMNI_JSON_PATH = "C:\\path\\to\\private\\company_alumni.json"
#$env:WATCHER_COMPANY_ALUMNI_JSON = '{"bosch":[{"name":"David Chu","occupation":"Commercial Project Management - APAC","linkedin_url":"https://www.linkedin.com/in/...","employer":"Bosch"}]}'

# Optional private full alumni roster location for watcher matching. Keep this
# file outside public git unless you intentionally publish it.
#$env:WATCHER_ALUMNI_CSV = "C:\\path\\to\\private\\alumni.csv"
#$env:WATCHER_REQUIRE_ALUMNI = "1"
# For GitHub Actions, prefer repository secret WATCHER_COMPANY_ALUMNI_JSON_B64:
#   base64 -w0 watcher/company_alumni.json
# The workflow falls back to full CSV secret WATCHER_ALUMNI_CSV_B64:
#   base64 -w0 watcher/alumni.csv
# The workflow also accepts ALUMNI_CSV_B64, WATCHER_ALUMNI_CSV_TEXT,
# WATCHER_ALUMNI_CSV, ALUMNI_CSV_TEXT, or ALUMNI_CSV as fallback secret names.
