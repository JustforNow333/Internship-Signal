# Internship Signal — optional settings. Everything works with defaults;
# copy to .env and uncomment only what you need.

# --- backend -----------------------------------------------------------
# Host/port uvicorn binds to (passed on the command line in the README,
# listed here for completeness):
#   uvicorn app.main:app --host $BACKEND_HOST --port $BACKEND_PORT
#BACKEND_HOST=127.0.0.1
#BACKEND_PORT=8000

# Comma-separated origins allowed by CORS (only needed if you serve the
# frontend from somewhere other than the Vite dev proxy).
#CORS_ORIGINS=http://localhost:5173

# Override the bundled data files:
#KNOWN_COMPANIES_PATH=./data/known_companies.json
#PROFILE_PATH=./data/profile.json
#SAMPLE_CSV_PATH=./data/sample_postings.csv

# --- frontend ----------------------------------------------------------
# Where the Vite dev server proxies /api requests (default shown).
#VITE_API_BASE=http://localhost:8000

# --- watcher email -----------------------------------------------------
# PowerShell examples for enabling live Gmail SMTP sends:
$env:SMTP_USER = "youraddress@gmail.com"
$env:SMTP_APP_PASSWORD = "abcdefghijklmnop"
$env:EMAIL_TO = "youraddress@gmail.com"
$env:WATCHER_SEND_EMAIL = "1"

# Optional private alumni roster location for watcher matching. Keep this file
# outside public git unless you intentionally publish it.
#$env:WATCHER_ALUMNI_CSV = "C:\\path\\to\\private\\alumni.csv"
#$env:WATCHER_REQUIRE_ALUMNI = "1"
